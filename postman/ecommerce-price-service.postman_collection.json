  "item": [
    {
      "name": "Test 1 – 10:00 on 14th (price list 1, €35.50)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/prices?applicationDate=2020-06-14T10:00:00&productId={{productId}}&brandId={{brandId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "prices"],
          "query": [
            {
              "key": "applicationDate",
              "value": "2020-06-14T10:00:00",
              "description": "Application date/time (ISO-8601)"
            },
            {
              "key": "productId",
              "value": "{{productId}}",
              "description": "Product identifier"
            },
            {
              "key": "brandId",
              "value": "{{brandId}}",
              "description": "Brand identifier (1 = ZARA)"
            }
          ]
        },
        "description": "Request at 10:00 on the 14th for product 35455 and brand 1.\nExpected: price list 1, price €35.50 (only tariff 1 is active at this time)."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Price list is 1', () => pm.expect(pm.response.json().priceList).to.eql(1));",
              "pm.test('Price is 35.50', () => pm.expect(pm.response.json().price).to.eql(35.50));",
              "pm.test('Currency is EUR', () => pm.expect(pm.response.json().currency).to.eql('EUR'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
